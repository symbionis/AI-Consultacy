---
// Cal.com floating "Book 15 min" button. Rendered once from Layout, so it
// appears on every page (home, about, framework — EN and FR). This is the
// site's only Cal embed: it loads embed.js, inits the `connect` namespace, and
// sets the themed `ui` config. The in-page CTAs (data-cal-link buttons) reuse
// that same namespace via Cal's global element-click delegation — no per-page
// init needed — so clicking them opens the same popup as this button.
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const buttonText = locale === 'fr' ? 'Réserver 15 min' : 'Book 15 min';

// Numeric ID of the LinkedIn event-specific conversion fired on a completed
// booking. Null locally / when unset — the listener then does nothing.
// The Insight Tag base pixel itself lives in Layout.astro.
const linkedInConversionId = import.meta.env.PUBLIC_LINKEDIN_CONVERSION_ID || null;
---

<script is:inline define:vars={{ buttonText, linkedInConversionId }}>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", "connect", { origin: "https://app.cal.com" });
  Cal.ns.connect("floatingButton", {
    calLink: "franksy/connect",
    config: { layout: "month_view", useSlotsViewOnSmallScreen: "true" },
    buttonColor: "#1B3A57",
    buttonTextColor: "#F4F1EA",
    buttonText: buttonText,
    buttonPosition: "bottom-right",
  });
  Cal.ns.connect("ui", {
    theme: "light",
    hideEventTypeDetails: false,
    layout: "month_view",
    cssVarsPerTheme: {
      light: {
        "cal-bg": "#F4F1EA",
        "cal-bg-muted": "#EEEAE0",
        "cal-bg-emphasis": "#EEEAE0",
        "cal-brand": "#1B3A57",
        "cal-text": "#1B3A57",
        "cal-text-emphasis": "#1B3A57",
      },
    },
  });

  // The in-page CTAs are anchors (data-cal-link) with an app.cal.com href as a
  // no-JS fallback. Cal's element-click handler opens the modal but does not
  // cancel the anchor's navigation, so without this the browser would follow
  // the href and unload the page. Suppress the default only when JS is active.
  document.addEventListener("click", function (e) {
    if (e.target.closest("a[data-cal-link]")) e.preventDefault();
  });

  // Fire conversion tracking when a booking completes in the popup. One listener
  // on the shared `connect` namespace covers the floating button and every
  // in-page CTA, on every page. `bookingSuccessful` is the long-standing event;
  // `bookingSuccessfulV2` is its successor — listen to both and dedupe so a
  // single booking counts once regardless of which the embed emits.
  (function () {
    var counted = false;
    function onBookingComplete() {
      if (counted) return;
      counted = true;
      if (window.lintrk && linkedInConversionId) {
        window.lintrk("track", { conversion_id: Number(linkedInConversionId) });
      }
    }
    Cal.ns.connect("on", { action: "bookingSuccessful", callback: onBookingComplete });
    Cal.ns.connect("on", { action: "bookingSuccessfulV2", callback: onBookingComplete });
  })();
</script>
