# LinkedIn Insight Tag — ad conversion tracking for the LinkedIn campaigns.
# PARTNER_ID installs the base pixel site-wide (Campaign Manager → Analyze →
# Insight Tag). CONVERSION_ID is the numeric ID of the event-specific conversion
# (Campaign Manager → Conversion tracking) fired when a Cal booking completes.
# Set both in Cloudflare Pages → Environment variables (Production scope); leave
# unset locally to skip the tag and avoid polluting conversion data during dev.
PUBLIC_LINKEDIN_PARTNER_ID=
PUBLIC_LINKEDIN_CONVERSION_ID=
