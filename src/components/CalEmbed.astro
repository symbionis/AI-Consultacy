---
// Cal.com inline booking embed. Rendered per page (the homepages and the
// framework pages each have one; the about pages have none), so the loader
// and init script are page-scoped rather than global. The element id differs
// per page — `cal-inline` on the homepages, `my-cal-inline-connect` on the
// framework pages — and is passed through to the init call.
interface Props {
  elementId: string;
  containerStyle?: string;
}

const { elementId, containerStyle } = Astro.props;
---

<div class="cal-inline-wrap" id={elementId} style={containerStyle}></div>

<script is:inline define:vars={{ elementId }}>
  (function (C, A, L) { let p = function (a, ar) { a.q.push(ar); }; let d = C.document; C.Cal = C.Cal || function () { let cal = C.Cal; let ar = arguments; if (!cal.loaded) { cal.ns = {}; cal.q = cal.q || []; d.head.appendChild(d.createElement("script")).src = A; cal.loaded = true; } if (ar[0] === L) { const api = function () { p(api, arguments); }; const namespace = ar[1]; api.q = api.q || []; if(typeof namespace === "string"){cal.ns[namespace] = cal.ns[namespace] || api;p(cal.ns[namespace], ar);p(cal, ["initNamespace", namespace]);} else p(cal, ar); return;} p(cal, ar); }; })(window, "https://app.cal.com/embed/embed.js", "init");
  Cal("init", "connect", { origin: "https://app.cal.com" });
  Cal.ns.connect("inline", {
    elementOrSelector: "#" + elementId,
    config: { layout: "month_view", useSlotsViewOnSmallScreen: "true" },
    calLink: "franksy/connect",
  });
  Cal.ns.connect("ui", {
    theme: "light",
    hideEventTypeDetails: false,
    layout: "month_view",
    cssVarsPerTheme: {
      light: {
        "cal-bg": "#F4F1EA",
        "cal-bg-muted": "#EEEAE0",
        "cal-bg-emphasis": "#EEEAE0",
        "cal-brand": "#1B3A57",
        "cal-text": "#1B3A57",
        "cal-text-emphasis": "#1B3A57",
      },
    },
  });
</script>
